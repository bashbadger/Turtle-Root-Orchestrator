#!/usr/bin/env python3
import os
import sys
import subprocess
import threading
import discord
import json
import time
import requests
import secrets
import shutil
from datetime import datetime
from flask import Flask, request, jsonify
from flask_cors import CORS
from cryptography.hazmat.primitives.asymmetric import padding
from cryptography.hazmat.primitives import hashes, serialization
from cryptography.hazmat.backends import default_backend
import base64

# --- TURTLE SHIELD: ROUTE VALIDATION ---
# Enables the "touching turtle routes to main" requirement
IS_CLI = sys.argv[0].endswith('turtle') or len(sys.argv) > 1

app = Flask(__name__)
CORS(app)

# Load Sovereignty Config (Defaults provided for simulation)
DEVELOPER_ID = int(os.getenv("MY_DISCORD_ID", "0"))
EXTENSION_API_KEY = os.getenv("EXTENSION_API_KEY", secrets.token_urlsafe(16))
OLLAMA_HOST = os.getenv("OLLAMA_HOST", "http://localhost:11434")
LLM_MODEL = os.getenv("LLM_MODEL", "phi3:mini") 

DATA_DIR = "turtle_vault"
AUDIT_LOG_PATH = f"{DATA_DIR}/logs/system_audit_trail.jsonl"
INTERCEPT_LOG_PATH = f"{DATA_DIR}/compliance/lawful_intercept_ledger.jsonl"

log_buffer = []
intercept_buffer = []
buffer_lock = threading.Lock()

# Observer Thresholds
TEMP_CRITICAL = 82.0
MEM_CRITICAL = 92.0

for path in ["logs", "compliance", "agents"]:
    os.makedirs(f"{DATA_DIR}/{path}", exist_ok=True)

# --- 1. SOVEREIGN LOGGING & COMPLIANCE ---
class ShieldCompliance:
    def __init__(self):
        pub_raw = os.getenv("COMPLIANCE_PUBLIC_KEY", "")
        self.public_key = None
        if pub_raw:
            try:
                self.public_key = serialization.load_pem_public_key(
                    pub_raw.encode().replace('\\n', '\n'),
                    backend=default_backend()
                )
            except Exception as e:
                print(f"⚠️ Compliance Key Error: {e}")

    def encrypt_data(self, data_str):
        if not self.public_key:
            return "UNENCRYPTED_DATA"
        encrypted = self.public_key.encrypt(
            data_str.encode(),
            padding.OAEP(mgf=padding.MGF1(algorithm=hashes.SHA256()), algorithm=hashes.SHA256(), label=None)
        )
        return base64.b64encode(encrypted).decode()

    def map_identity(self, user_id, target):
        secret = secrets.token_hex(16)
        entry = {
            "timestamp": datetime.utcnow().isoformat(),
            "uid": user_id,
            "target": target,
            "secret_enc": self.encrypt_data(secret)
        }
        with buffer_lock:
            intercept_buffer.append(json.dumps(entry) + "\n")
        return secret

compliance = ShieldCompliance()

# --- 2. ACTIVE OBSERVER ---
class ActiveObserver:
    def __init__(self):
        self.posture = "NORMAL"
        self.breach_start = None

    def observe(self):
        while True:
            try:
                # Real Pi Temp check
                temp_raw = subprocess.run(["vcgencmd", "measure_temp"], capture_output=True, text=True).stdout
                temp = float(temp_raw.replace("temp=", "").replace("'C\n", ""))
            except:
                temp = 40.0 # Simulator default

            if temp > TEMP_CRITICAL:
                if not self.breach_start: self.breach_start = time.time()
                if (time.time() - self.breach_start) > 300: # 5 Mins
                    self._resurrection_pulse()
                else:
                    self.posture = "DEFENSIVE_THERMAL"
                    subprocess.run(["pkill", "-f", "ollama"], capture_output=True)
            else:
                self.breach_start = None
                self.posture = "NORMAL"
            time.sleep(10)

    def _resurrection_pulse(self):
        perform_flush()
        print("🚨 Sustained Thermal Breach. Cooling cycle initiated.")
        os.system("sudo shutdown -r +10")

observer = ActiveObserver()
threading.Thread(target=observer.observe, daemon=True).start()

# --- 3. SYSTEM GRASP ---
def execute_turt(task, actor):
    # Intent translation via local Ollama
    prompt = f"Linux Shell expert. Task: {task}. Return ONLY raw CLI command."
    try:
        res = requests.post(f"{OLLAMA_HOST}/api/generate", json={
            "model": LLM_MODEL, "prompt": prompt, "stream": False
        }, timeout=10).json().get("response", "").strip().replace("`", "")
    except:
        res = f"echo '⚠️ Local brain offline. Manual input for: {task}'"

    with buffer_lock:
        log_buffer.append(json.dumps({"t": datetime.utcnow().isoformat(), "a": actor, "c": res}) + "\n")
    
    try:
        result = subprocess.run(res, shell=True, capture_output=True, text=True, timeout=30)
        return f"🐢 **Turt Result:**\n```\n{result.stdout if result.stdout else result.stderr}\n```"
    except Exception as e:
        return f"❌ Grasp Error: {str(e)}"

# --- 4. DISCORD INTERFACE ---
intents = discord.Intents.default()
intents.message_content = True
intents.members = True
client = discord.Client(intents=intents)

@client.event
async def on_ready():
    print(f"🐢 Turtle Shield PRO | Route: {'CLI' if IS_CLI else 'Service'}")

@client.event
async def on_message(message):
    if message.author == client.user: return
    uid = str(message.author.id)

    if message.content.startswith("!broadcast"):
        target = message.content.replace("!broadcast", "").strip()
        session = compliance.map_identity(uid, target)
        await message.channel.send(f"✅ Identity mapped. Session: `{session[:8]}...` to `{target}`")

    if int(uid) == DEVELOPER_ID:
        if message.content.startswith("!turt"):
            await message.channel.send("🧠 Consulting local brain...")
            await message.channel.send(execute_turt(message.content.replace("!turt", "").strip(), uid))
        elif message.content == "!purge":
            with buffer_lock:
                log_buffer.clear()
                intercept_buffer.clear()
            shutil.rmtree(f"{DATA_DIR}/agents", ignore_errors=True)
            os.makedirs(f"{DATA_DIR}/agents", exist_ok=True)
            await message.channel.send("💀 **PURGE COMPLETE.** Node is dark.")

# --- 5. API & FLUSH ---
def perform_flush():
    global log_buffer, intercept_buffer
    with buffer_lock:
        if log_buffer:
            with open(AUDIT_LOG_PATH, "a") as f: f.writelines(log_buffer)
            log_buffer.clear()
        if intercept_buffer:
            with open(INTERCEPT_LOG_PATH, "a") as f: f.writelines(intercept_buffer)
            intercept_buffer.clear()

@app.route("/api/telemetry", methods=['GET'])
def api_telemetry():
    return jsonify({"posture": observer.posture, "buffer": len(log_buffer)})

if __name__ == "__main__":
    if len(sys.argv) > 1:
        print(execute_turt(" ".join(sys.argv[1:]), "LOCAL_ROOT"))
        sys.exit(0)
    threading.Thread(target=lambda: app.run(host='0.0.0.0', port=8080)).start()
    client.run(os.getenv("DISCORD_BOT_TOKEN"))
